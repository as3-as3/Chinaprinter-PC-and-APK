# Normalisiere Zeilenenden
* text=auto eol=lf

# Windows-Skripte brauchen CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix-Skripte MÜSSEN LF behalten (sonst nicht ausführbar)
gradlew text eol=lf

# Binärdateien nicht anfassen
*.jar binary
*.apk binary
*.zip binary
*.ico binary
*.png binary
*.jpg binary
*.woff binary
*.ttf binary
